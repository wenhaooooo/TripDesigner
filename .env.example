# 复制本文件为 .env 并填入真实值

# PostgreSQL 数据库配置
POSTGRES_DB=tripdesigner
POSTGRES_USER=tripdesigner
POSTGRES_PASSWORD=tripdesigner

# JWT Secret（请使用 openssl rand -base64 48 生成，至少 256 位）
JWT_SECRET=

# AI 大模型配置（Sensenova）
AI_BASE_URL=https://token.sensenova.cn
AI_API_KEY=
AI_MODEL=sensenova-6.7-flash-lite

# RabbitMQ 配置（LLM 推理任务队列）
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
