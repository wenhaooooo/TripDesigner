spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/tripdesigner
    username: tripdesigner
    password: tripdesigner
  data:
    redis:
      host: localhost
      port: 6379
  flyway:
    enabled: true

# 本地开发用 AI 大模型配置（请替换为你的真实凭据）
# 推荐：复制本文件为 application-local.yml，并填入真实值
spring.ai:
  openai:
    base-url: https://token.sensenova.cn
    api-key: YOUR_SENSENVA_API_KEY_HERE
    chat:
      options:
        model: sensenova-6.7-flash-lite
        stream: false

# 本地开发用 JWT Secret（请使用 openssl rand -base64 48 生成）
jwt:
  secret: PLEASE_GENERATE_WITH_OPENSSL_RAND_BASE64_48
